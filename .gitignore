# Dependency directories (โฟลเดอร์ติดตั้งไลบรารีภายนอก)
node_modules/

# Build outputs (โฟลเดอร์ประมวลผลปลายทางสำหรับนำไปวางเซิร์ฟเวอร์)
dist/
build/

# IDE and Editor files (ไฟล์การตั้งค่าโปรแกรมเขียนโค้ดส่วนบุคคล)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS metadata (ไฟล์ประวัติสารสนเทศของระบบปฏิบัติการ)
.DS_Store
Thumbs.db

# Scrap files and local configs (ไฟล์ทดสอบ และคีย์เชื่อมต่อความปลอดภัยเฉพาะตัว)
scratch/
test_sheet.csv
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs (ประวัติข้อผิดพลาดสะสม)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
